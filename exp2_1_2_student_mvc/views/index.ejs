
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <title><%= title %></title>
  <style>
    body {
      font-family: 'Segoe UI', sans-serif;
      max-width: 950px;
      margin: 30px auto;
      padding: 0 25px;
      background: #eef1f7;
    }

    h1 {
      color: #444;
      border-bottom: 2px solid #6f42c1;
      padding-bottom: 8px;
    }

    .btn {
      padding: 7px 14px;
      border: none;
      border-radius: 6px;
      cursor: pointer;
      text-decoration: none;
      font-size: 13px;
      transition: 0.2s;
    }

    .btn-primary {
      background: #6f42c1;
      color: white;
    }

    .btn-warning {
      background: #f0ad4e;
      color: #222;
    }

    .btn-danger {
      background: #c82333;
      color: white;
    }

    .btn:hover {
      opacity: 0.9;
    }

    table {
      width: 100%;
      border-collapse: collapse;
      background: #ffffff;
      box-shadow: 0 3px 10px rgba(0,0,0,0.08);
      border-radius: 10px;
      overflow: hidden;
    }

    th {
      background: #6f42c1;
      color: white;
      padding: 10px;
      text-align: left;
    }

    td {
      padding: 10px;
      border-bottom: 1px solid #ddd;
    }

    tr:last-child td {
      border-bottom: none;
    }

    tr:hover td {
      background: #f3ecff;
    }

    .actions {
      display: flex;
      gap: 6px;
    }

    .top-bar {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 15px;
    }

    .count {
      color: #555;
      font-size: 13px;
    }
  </style>
</head>
<body>

  <h1>📘 Student Record Manager</h1>

  <div class="top-bar">
    <span class="count">Students Count: <strong><%= students.length %></strong></span>
    <a href="/students/new" class="btn btn-primary">+ Add Student</a>
  </div>

  <% if (students.length === 0) { %>
    <p style="text-align:center; color:#888; padding:35px;">
      No records available. Please add a student.
    </p>
  <% } else { %>

    <table>
      <thead>
        <tr>
          <th>Roll No</th>
          <th>Full Name</th>
          <th>Email ID</th>
          <th>Course</th>
          <th>Marks</th>
          <th>Options</th>
        </tr>
      </thead>

      <tbody>
        <% students.forEach(stu => { %>
          <tr>
            <td><%= stu.roll %></td>
            <td><%= stu.name %></td>
            <td><%= stu.email %></td>
            <td><%= stu.course %></td>
            <td><%= stu.marks %></td>

            <td class="actions">
              <a href="/students/<%= stu._id %>/edit" class="btn btn-warning">Update</a>

              <form action="/students/<%= stu._id %>/delete" method="POST"
                    onsubmit="return confirm('Are you sure you want to remove this record?')">
                <button type="submit" class="btn btn-danger">Remove</button>
              </form>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>

  <% } %>

</body>
</html>
