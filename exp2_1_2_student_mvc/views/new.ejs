<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <title><%= title %></title>

  <style>
    body {
      font-family: 'Segoe UI', sans-serif;
      max-width: 520px;
      margin: 35px auto;
      padding: 0 25px;
      background: #eef2f7;
    }

    h1 {
      text-align: center;
      color: #444;
    }

    form {
      background: #fff;
      padding: 25px;
      border-radius: 10px;
      box-shadow: 0 3px 10px rgba(0,0,0,0.08);
    }

    label {
      display: block;
      margin-bottom: 5px;
      font-weight: 600;
      font-size: 13px;
    }

    input {
      width: 100%;
      padding: 9px;
      margin-bottom: 14px;
      border-radius: 6px;
      border: 1px solid #ccc;
    }

    .btn-row {
      display: flex;
      gap: 8px;
    }

    .btn {
      padding: 9px 18px;
      border: none;
      border-radius: 6px;
      cursor: pointer;
    }

    .btn-primary { background: #28a745; color: white; }
    .btn-secondary { background: #6c757d; color: white; }
  </style>
</head>

<body>

  <h1>📝 Register Student</h1>

  <form action="/students" method="POST">

    <label>Name</label>
    <input type="text" name="name" required />

    <label>Roll Number</label>
    <input type="number" name="roll" required />

    <label>Email</label>
    <input type="email" name="email" required />

    <label>Course</label>
    <input type="text" name="course" value="B.Tech CSE" required />

    <label>Marks</label>
    <input type="number" name="marks" min="0" max="100" />

    <div class="btn-row">
      <button type="submit" class="btn btn-primary">Submit</button>
      <a href="/students" class="btn btn-secondary">Back</a>
    </div>

  </form>

</body>
</html>
