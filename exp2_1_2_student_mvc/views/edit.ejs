<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <title><%= title %></title>
  <style>
    body  { font-family: Arial; max-width: 500px; margin: 40px auto; padding: 0 20px; background: #f5f5f5; }
    h1    { color: #333; }
    form  { background: white; padding: 30px; border-radius: 8px; box-shadow: 0 2px 8px rgba(0,0,0,0.1); }
    label { display: block; margin-bottom: 4px; font-weight: bold; color: #555; font-size: 14px; }
    input { width: 100%; padding: 10px; margin-bottom: 16px; border: 1px solid #ddd; border-radius: 4px; font-size: 14px; box-sizing: border-box; }
    .btn-row { display: flex; gap: 10px; }
    .btn  { padding: 10px 20px; border: none; border-radius: 4px; cursor: pointer; font-size: 14px; text-decoration: none; }
    .btn-success   { background: #28a745; color: white; }
    .btn-secondary { background: #6c757d; color: white; }
  </style>
</head>
<body>
  <h1>✏️ Edit Student</h1>
  <!-- Posts to /students/:id/update → updateStudent controller -->
  <form action="/students/<%= student._id %>/update" method="POST">
    <label>Name</label>
    <!-- value="<%= %>" pre-fills the form with existing data -->
    <input type="text" name="name" value="<%= student.name %>" required />

    <label>Roll Number</label>
    <input type="number" name="roll" value="<%= student.roll %>" required min="1" />

    <label>Email</label>
    <input type="email" name="email" value="<%= student.email %>" required />

    <label>Course</label>
    <input type="text" name="course" value="<%= student.course %>" required />

    <label>Marks (0–100)</label>
    <input type="number" name="marks" value="<%= student.marks %>" min="0" max="100" />

    <div class="btn-row">
      <button type="submit" class="btn btn-success">Update Student</button>
      <a href="/students" class="btn btn-secondary">Cancel</a>
    </div>
  </form>
</body>
</html>
